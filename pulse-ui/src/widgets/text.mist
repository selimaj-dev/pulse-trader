pub module text;

use super::widget::Widget;
use crate::render_scope;

pub class Text : Widget {
    String text;

    pub constructor(str& text)
    {
        super = Super::new();
        self.text = text.to_string();
    }

    pub virtual void render(&self, render_scope::RenderStack mut& stack) override
    {
        render_scope::RenderScope mut& scope = stack.push();
    }
}
