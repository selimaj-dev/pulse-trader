pub module widget;

use crate::units;
use crate::render_scope;

pub class Widget
{
    units::Position x = units::Position::Char(0);
    units::Position y = units::Position::Char(0);

    units::Size width = units::Size::Full;
    units::Size height = units::Size::Full;

    pub constructor() {}

    pub virtual void render(&self, render_scope::RenderStack mut& stack) {
        let _ = stack;
    }

    pub virtual void update(&self) {}
}
